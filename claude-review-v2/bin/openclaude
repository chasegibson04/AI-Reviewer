#!/usr/bin/env node

/**
 * claude-review-v2 launcher.
 *
 * Delegates to scripts/launch.js for cross-platform startup behavior.
 */

import { existsSync } from 'fs'
import { join, dirname } from 'path'
import { fileURLToPath, pathToFileURL } from 'url'

const __dirname = dirname(fileURLToPath(import.meta.url))
const launchPath = join(__dirname, '..', 'scripts', 'launch.js')

if (existsSync(launchPath)) {
  await import(pathToFileURL(launchPath).href)
} else {
  console.error(`
  claude-review-v2: scripts/launch.js not found.

  This installation is incomplete.
  Reinstall and verify that scripts/launch.js exists.

  See README.md for setup instructions.
`)
  process.exit(1)
}
