{
  "name": "claude-review",
  "version": "0.1.0",
  "description": "Advanced terminal-based manuscript review and editing system",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "claude-review": "./bin/claude-review.js"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "test": "bun test",
    "lint": "bun x eslint src/**/*.ts",
    "typecheck": "bun x tsc --noEmit",
    "doctor": "bun src/index.ts doctor",
    "doctor:runtime": "bun src/index.ts doctor --runtime",
    "doctor:runtime:json": "bun src/index.ts doctor --runtime --json",
    "smoke": "bun tests/smoke.test.ts",
    "benchmark": "bun src/index.ts benchmark",
    "hardening:check": "bun run smoke && bun run doctor:runtime",
    "hardening:strict": "bun run typecheck && bun run hardening:check && bun run test"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "axios": "^1.14.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "date-fns": "^3.3.1",
    "docx": "^8.5.0",
    "dotenv": "^16.4.1",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "ink": "^4.4.1",
    "mammoth": "^1.6.0",
    "openai": "^4.26.0",
    "ora": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "uuid": "^13.0.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.16",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.2.0",
    "typescript": "^5.3.3"
  }
}
